PORT=4000
NODE_ENV=development

# PostgreSQL (default)
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# SQLite alternative (no server needed, great for local dev)
# DATABASE_URL=file:./dev.db

# JWT — generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-in-production-access-secret
JWT_REFRESH_EXPIRES_DAYS=7

# Session — generate secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-in-production-session-secret

# CORS — comma-separated allowed origins (e.g. https://app.example.com,https://admin.example.com)
# Unset in production blocks all cross-origin requests. Unset in development defaults to *.
CORS_ORIGIN=

# Rate limiting — general (all routes): defaults 100 req / 15 min per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Rate limiting — auth routes (stricter): defaults 10 req / 15 min per IP
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

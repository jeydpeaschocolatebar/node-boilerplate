{
    "name": "node-boilerplate",
    "version": "0.0.1",
    "description": "A simple Node.js boilerplate with TypeScript, Express, and Zod",
    "main": "src/app.ts",
    "license": "MIT",
    "scripts": {
        "prepare": "husky install",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "build": "tsc",
        "start": "node dist/app.js",
        "dev": "nodemon --watch src/ --exec ts-node src/app.ts",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jeydpeaschocolatebar/node-boilerplate.git"
    },
    "keywords": [
        "node",
        "server",
        "api",
        "boiler-plate"
    ],
    "author": "Jade Francis Palco",
    "bugs": {
        "url": "https://github.com/jeydpeaschocolatebar/node-boilerplate/issues"
    },
    "homepage": "https://github.com/jeydpeaschocolatebar/node-boilerplate#readme",
    "dependencies": {
        "@prisma/client": "^6.19.3",
        "bcryptjs": "^3.0.3",
        "dotenv": "^16.5.0",
        "express": "^5.1.0",
        "jsonwebtoken": "^9.0.3",
        "zod": "^3.25.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.27.0",
        "@types/bcryptjs": "^3.0.0",
        "@types/express": "^5.0.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.15.19",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^8.32.1",
        "@typescript-eslint/parser": "^8.32.1",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-prettier": "^5.4.0",
        "globals": "^16.1.0",
        "husky": "^9.1.7",
        "jiti": "^2.4.2",
        "lint-staged": "^16.0.0",
        "nodemon": "^3.1.10",
        "prettier": "^3.5.3",
        "prisma": "^6.19.3",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.1",
        "vitest": "^4.1.5"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "prisma"
        ]
    },
    "lint-staged": {
        "*.{ts,js,json,md}": [
            "eslint --fix",
            "prettier --write",
            "git add"
        ]
    }
}
